<!doctype html>
<html lang="{{ locale|default('cs') }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ subject|default('MyInvoice.cz') }}</title>
</head>
{% set accent = (supplier and supplier.email_accent_color) ? supplier.email_accent_color : '#3B2D83' %}
{% set branded = (supplier and supplier.email_branding_enabled) %}
{% set has_logo = (branded and supplier.logo_path) %}
<body style="margin:0;padding:0;background:#F4F2F8;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#15131D;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#F4F2F8;padding:32px 16px;">
  <tr>
    <td align="center">

      {# ─── HLAVIČKA ─── #}
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;background:#ffffff;border:1px solid #E7E3EE;border-radius:12px;overflow:hidden;">
        <tr>
          <td style="padding:24px 32px;border-bottom:1px solid #E7E3EE;background:linear-gradient(180deg,#F4F2FB 0%,#ffffff 100%);">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td style="vertical-align:middle;">
                  {% if has_logo %}
                    {# Per-supplier logo (CID inline image v emailu, data URI v preview).
                       HTML width/height atributy jsou klíčové — Outlook a další klienti
                       CSS max-height na <img> ignorují. Rozměry pre-počítané server-side
                       z file dimenzí (Mailer::addLogoDisplaySize). #}
                    {% set lw = supplier.logo_display_width|default(0) %}
                    {% set lh = supplier.logo_display_height|default(48) %}
                    <img src="{{ supplier.logo_inline_src|default('cid:supplier_logo') }}"
                         alt="{{ (supplier.display_name|default(supplier.company_name)) }}"
                         {% if lw > 0 %}width="{{ lw }}" {% endif %}height="{{ lh }}"
                         style="display:block;height:{{ lh }}px;{% if lw > 0 %}width:{{ lw }}px;{% endif %}max-width:280px;border:0;">
                  {% else %}
                    {# Fallback: MyInvoice „M" box (default branding) #}
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:36px;height:36px;background:{{ accent }};border-radius:8px;">
                      <tr>
                        <td align="center" valign="middle" style="color:#ffffff;font-weight:700;font-size:20px;line-height:36px;font-family:Arial,sans-serif;">M</td>
                      </tr>
                    </table>
                  {% endif %}
                </td>
                <td style="vertical-align:middle;padding-left:12px;">
                  {% if branded %}
                    <div style="font-size:18px;font-weight:600;color:#15131D;line-height:1.2;">{{ supplier.display_name|default(supplier.company_name) }}</div>
                    {% if supplier.tagline %}
                      <div style="font-size:12px;color:#7A748C;line-height:1.4;margin-top:2px;">{{ supplier.tagline }}</div>
                    {% endif %}
                  {% else %}
                    <div style="font-size:18px;font-weight:600;color:#15131D;line-height:1.2;">My<span style="color:{{ accent }};">Invoice</span><span style="color:#7A748C;font-weight:400;">.cz</span></div>
                    <div style="font-size:12px;color:#7A748C;line-height:1.4;margin-top:2px;">{{ locale == 'en' ? 'Invoicing system' : 'Fakturační systém' }}</div>
                  {% endif %}
                </td>
              </tr>
            </table>
          </td>
        </tr>

        {# ─── OBSAH ─── #}
        <tr>
          <td style="padding:32px;font-size:15px;line-height:1.6;color:#403B52;">
            {% block content %}{% endblock %}
          </td>
        </tr>

        {# ─── PATIČKA — vše z DB (supplier table) ─── #}
        {% if supplier %}
        <tr>
          <td style="padding:24px 32px;border-top:1px solid #E7E3EE;background:#FBFAFD;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="font-size:13px;line-height:1.6;color:#5A5470;">
              {% if supplier.display_name or supplier.tagline %}
              <tr>
                <td style="padding-bottom:12px;">
                  {% if supplier.display_name %}<strong style="color:#15131D;font-size:14px;">{{ supplier.display_name }}</strong><br>{% endif %}
                  {% if supplier.tagline %}<span style="color:#7A748C;font-style:italic;">{{ supplier.tagline }}</span><br>{% endif %}
                  {% if supplier.email %}<a href="mailto:{{ supplier.email }}" style="color:{{ accent }};text-decoration:none;">{{ supplier.email }}</a>{% endif %}
                </td>
              </tr>
              {% endif %}
              <tr>
                <td style="padding-top:{{ (supplier.display_name or supplier.tagline) ? '12px' : '0' }};border-top:{{ (supplier.display_name or supplier.tagline) ? '1px solid #E7E3EE' : 'none' }};">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="font-size:12px;color:#7A748C;">
                    <tr>
                      <td style="vertical-align:top;">
                        <strong style="color:#5A5470;">{{ supplier.company_name }}</strong><br>
                        {{ supplier.street }}<br>
                        {{ supplier.zip }} {{ supplier.city }}{% if supplier.country %}, {{ supplier.country }}{% endif %}
                      </td>
                      <td style="vertical-align:top;text-align:right;">
                        {% if supplier.phone %}<a href="tel:{{ supplier.phone|replace({' ': ''}) }}" style="color:#5A5470;text-decoration:none;font-variant-numeric:tabular-nums;">{{ supplier.phone }}</a><br>{% endif %}
                        {% if supplier.web %}<a href="{{ supplier.web }}" style="color:#7A748C;text-decoration:none;">{{ supplier.web|replace({'https://': '', 'http://': ''}) }}</a>{% endif %}
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        {% endif %}
      </table>

      <p style="max-width:560px;font-size:11px;color:#A7A0BA;margin:16px auto 0;text-align:center;">
        {% if locale == 'en' %}
          This email was sent automatically. If you did not request it, please contact{% if supplier and supplier.email %} <a href="mailto:{{ supplier.email }}" style="color:#7A748C;">{{ supplier.email }}</a>{% else %} the sender{% endif %}.<br>
          Powered by <a href="https://myinvoice.cz/" style="color:#7A748C;text-decoration:none;">MyInvoice.cz</a> invoicing system.
        {% else %}
          Tento email byl odeslán automaticky. Pokud jste o něj nežádali, kontaktujte{% if supplier and supplier.email %} <a href="mailto:{{ supplier.email }}" style="color:#7A748C;">{{ supplier.email }}</a>{% else %} odesílatele{% endif %}.<br>
          Používá fakturační systém <a href="https://myinvoice.cz/" style="color:#7A748C;text-decoration:none;">MyInvoice.cz</a>.
        {% endif %}
      </p>

    </td>
  </tr>
</table>

</body>
</html>
