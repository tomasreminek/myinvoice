# MyInvoice.cz — Apache configuration
#
# /api/*        → api/public/index.php (Slim FrontController)
# statika       → /styles/, /assets/ napřímo
# SPA fallback  → web/dist/index.html

Options -Indexes -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1) Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https  <-- PŘIDÁNO
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]


    # 2) Bezpečnostní bariéra: blokovat citlivé složky
    RewriteRule ^(private|db|log|source|storage|tools|node_modules|api/(src|vendor|templates|tests|bin))(/|$) - [F,L]

    # 2b) Blokovat cfg.php, composer.* a markdown v rootu
    RewriteRule ^(cfg\.php|cfg\.local\.php|composer\.(json|lock)|\.gitignore|\.env.*|[^/]*\.md|[^/]*\.sql)$ - [F,L]

    # 3a) /assets/* → web/dist/assets/* (Vite generuje absolutní URL `/assets/foo.css`,
    # ale skutečné soubory jsou v `web/dist/assets/`. V IIS to řeší alias z web.config,
    # v Apache musíme přepisovat zde.)
    RewriteCond %{REQUEST_URI} ^/assets/
    RewriteRule ^assets/(.*)$ web/dist/assets/$1 [L]

    # 3b) /manual a /manual?ch=... → manual/index.php (HTML manuál)
    # Statické soubory v /manual/generated/img/ a /manual/generated/search-index.json
    # se servírují přímo (mají reálné soubory). /manual/img/ (zdroj WEBP) je taky v
    # docroot a serveruje se přímo. Jen "pretty" /manual URL jde přes index.php.
    RewriteRule ^manual/?$ manual/index.php [L,QSA]

    # 3) /api/* → api/public/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^api/(.*)$ api/public/index.php [L,QSA]

    # 4) SPA fallback (vše co není reálný soubor a není /api/* → web/dist/index.html).
    # `!-d` schválně NEPOUŽÍVÁME, jinak by `/` (= docroot dir) tímhle pravidlem neprošlo
    # a Apache by hodil 403 (Options -Indexes + chybějící DirectoryIndex). Statické
    # cesty mají `!-f`, takže je rewrite vynechá.
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteCond %{REQUEST_URI} !^/manual
    RewriteCond %{REQUEST_URI} !^/styles/
    RewriteCond %{REQUEST_URI} !^/web/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ web/dist/index.html [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "same-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), accelerometer=(self \"https://challenges.cloudflare.com\"), gyroscope=(self \"https://challenges.cloudflare.com\"), magnetometer=(self \"https://challenges.cloudflare.com\"), xr-spatial-tracking=(self \"https://challenges.cloudflare.com\")"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-site"
    Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; font-src 'self'; connect-src 'self'; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# Static asset cache
<FilesMatch "\.(woff2|woff|ttf|otf|eot|js|css|svg|png|jpg|jpeg|webp|ico)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=31536000, immutable"
    </IfModule>
</FilesMatch>

# API responses nesmí být cache-ované.
# `<LocationMatch>` není povolený v .htaccess (jen ve server/vhost configu),
# takže používáme rewrite-env trick: nastavíme proměnnou NOCACHE pro /api/* a
# Header Cache-Control podle ní pošleme. Funguje napříč Apache + IIS + Docker.
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_URI} ^/api/
    RewriteRule ^ - [E=NOCACHE:1]
</IfModule>
<IfModule mod_headers.c>
    Header set Cache-Control "no-store" env=NOCACHE
</IfModule>

# Blokovat citlivé soubory.
# .md zdroje manuálu jsou blokované přímým přístupem — uživatel je dostane jen
# v HTML rendru přes /manual (PHP fopen čte filesystem, ne přes HTTP).
<FilesMatch "\.(env|sql|pem|log|lock|md|yaml|yml)$">
    Require all denied
</FilesMatch>

# Skrýt cfg.php přímo
<Files "cfg.php">
    Require all denied
</Files>
<Files "cfg.local.php">
    Require all denied
</Files>

# MIME
<IfModule mod_mime.c>
    AddType font/woff2 .woff2
    AddType font/woff  .woff
    AddType image/svg+xml .svg
</IfModule>

# Komprimace
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
